# Configuración de Variables de Entorno - Proecho

# ===============================================
# BASE DE DATOS
# ===============================================
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=your_password
DATABASE_NAME=provecho

# Cadena de conexión completa (alternativa)
DATABASE_URL=mysql://root:your_password@localhost:3306/provecho

# ===============================================
# SERVIDOR Y PUERTOS
# ===============================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# ===============================================
# AUTENTICACIÓN Y SEGURIDAD
# ===============================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=24h
BCRYPT_ROUNDS=10

# Refresh token
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRATION=7d

# ===============================================
# SERVICIOS EXTERNOS - PAGOS
# ===============================================
# Stripe
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# PayPal (alternativa)
PAYPAL_CLIENT_ID=xxxxxxxxxxxxx
PAYPAL_CLIENT_SECRET=xxxxxxxxxxxxx

# ===============================================
# EMAIL
# ===============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=Proecho
SMTP_FROM_EMAIL=noreply@proecho.com

# ===============================================
# GPS Y MAPAS
# ===============================================
# Google Maps
GOOGLE_MAPS_API_KEY=AIzaSyDxxxxxxxxxxxxx

# Alternativa: Mapbox
MAPBOX_TOKEN=pk.eyJxxxxxxxxxxxxxxx

# ===============================================
# ALMACENAMIENTO DE ARCHIVOS
# ===============================================
# AWS S3 (recomendado para producción)
AWS_ACCESS_KEY_ID=xxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxx
AWS_REGION=us-east-1
AWS_S3_BUCKET=proecho-images

# Alternativa: Local storage
FILE_UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# ===============================================
# NOTIFICACIONES
# ===============================================
# Firebase para push notifications
FIREBASE_PROJECT_ID=xxxxxxxxxxxxx
FIREBASE_PRIVATE_KEY=xxxxxxxxxxxxx
FIREBASE_CLIENT_EMAIL=xxxxxxxxxxxxx

# Twilio para SMS (opcional)
TWILIO_ACCOUNT_SID=xxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ===============================================
# ANALÍTICA Y LOGGING
# ===============================================
# Sentry para tracking de errores
SENTRY_DSN=https://xxxxxxxxxxxxx@sentry.io/xxxxx

# Google Analytics
GOOGLE_ANALYTICS_ID=UA-xxxxxxxxxxxxx

# Nivel de logging
LOG_LEVEL=info

# ===============================================
# APLICACIÓN - CONFIGURACIÓN DE NEGOCIO
# ===============================================
# Comisión por orden
PLATFORM_COMMISSION_PERCENTAGE=15

# Costo de envío base
DEFAULT_DELIVERY_FEE=2.99
DELIVERY_FEE_PER_KM=0.50

# Impuesto
TAX_PERCENTAGE=10

# Radio máximo de entrega (km)
MAX_DELIVERY_RADIUS=15

# Tiempo máximo de preparación (minutos)
MAX_PREPARATION_TIME=60

# ===============================================
# FRONTEND - VARIABLES REACT
# ===============================================
REACT_APP_API_URL=http://localhost:3001
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
REACT_APP_GOOGLE_MAPS_API_KEY=AIzaSyDxxxxxxxxxxxxx
REACT_APP_ENV=development
REACT_APP_VERSION=1.0.0

# ===============================================
# CORS Y SEGURIDAD
# ===============================================
# Orígenes permitidos para CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,https://proecho.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===============================================
# CACHING
# ===============================================
# Redis (opcional pero recomendado)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# TTL para caché (segundos)
CACHE_TTL=3600

# ===============================================
# ADMIN
# ===============================================
# Email de administrador
ADMIN_EMAIL=admin@proecho.com

# ===============================================
# DESARROLLO
# ===============================================
# Debug mode
DEBUG=false

# Seed data (para desarrollo)
SEED_DATABASE=false

# ===============================================
# NOTAS IMPORTANTES
# ===============================================
# 1. NUNCA hagas commit de este archivo con valores reales
# 2. Usa .gitignore para excluir .env
# 3. En producción, establece estas variables en tu servidor/plataforma
# 4. Usa valores seguros y únicos para cada entorno
# 5. Cambia todos los "xxxxxxxxxxxxx" por valores reales antes de usar
